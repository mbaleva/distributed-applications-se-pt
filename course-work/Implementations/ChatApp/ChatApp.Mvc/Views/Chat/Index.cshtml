@model System.Text.Json.JsonElement

@{
    ViewData["Title"] = "Chat";
}

<div class="row">
    <div class="col-md-4 border-end" style="height: 80vh; overflow-y: auto;">
        <h4>Your conversations</h4>
        <ul class="list-group" id="conversationsList">
            @foreach (var conv in Model.EnumerateArray())
            {
                var id = conv.GetProperty("id").GetInt32();
                var title = conv.GetProperty("title").GetString();
                <li class="list-group-item conversation-item" data-id="@id">
                    @title
                </li>
            }
        </ul>
    </div>
    <div class="col-md-8 d-flex flex-column" style="height: 80vh;">
        <div id="messages" class="flex-grow-1 border mb-2 p-2" style="overflow-y: auto;"></div>
        <div class="input-group">
            <input id="messageInput" class="form-control" placeholder="Type a message..." />
            <button id="sendButton" class="btn btn-primary">Send</button>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/7.0.5/signalr.min.js"></script>
    <script>
        let selectedConversationId = null;
        let connection = null;

        async function initConnection() {
            const token = getCookie("chat_jwt");
            connection = new signalR.HubConnectionBuilder()
                .withUrl("http://localhost:5001/hubs/chat", {
                    accessTokenFactory: () => token
                })
                .withAutomaticReconnect()
                .build();

            connection.on("ReceiveMessage", message => {
                if (selectedConversationId === message.conversationId) {
                    appendMessage(message);
                }
            });

            await connection.start();
        }

        function appendMessage(message) {
            const container = document.getElementById("messages");
            const div = document.createElement("div");
            div.textContent = message.content;
            container.appendChild(div);
            container.scrollTop = container.scrollHeight;
        }

        function getCookie(name) {
            const value = `; ${document.cookie}`;
            const parts = value.split(`; ${name}=`);
            if (parts.length === 2) return parts.pop().split(';').shift();
        }

        async function loadMessages(conversationId) {
            const token = getCookie("chat_jwt");
            const response = await fetch(`http://localhost:5001/api/conversations/${conversationId}/messages?page=1&pageSize=50`, {
                headers: {
                    "Authorization": `Bearer ${token}`
                }
            });
            if (!response.ok) {
                return;
            }
            const data = await response.json();
            const container = document.getElementById("messages");
            container.innerHTML = "";
            data.items.reverse().forEach(m => appendMessage(m));
        }

        document.addEventListener("DOMContentLoaded", async () => {
            await initConnection();

            document.querySelectorAll(".conversation-item").forEach(li => {
                li.addEventListener("click", async () => {
                    const id = parseInt(li.dataset.id);
                    if (selectedConversationId !== null) {
                        await connection.invoke("LeaveConversation", selectedConversationId);
                    }
                    selectedConversationId = id;
                    await connection.invoke("JoinConversation", id);
                    await loadMessages(id);
                });
            });

            document.getElementById("sendButton").addEventListener("click", async () => {
                const input = document.getElementById("messageInput");
                const text = input.value.trim();
                if (!text || selectedConversationId === null) return;
                await connection.invoke("SendMessage", selectedConversationId, text);
                input.value = "";
            });
        });
    </script>
}

